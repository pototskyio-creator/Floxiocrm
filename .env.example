# Database
# DATABASE_URL = admin role (POSTGRES_USER=floxio) — used by drizzle-kit, seed scripts.
# DATABASE_URL_APP = low-privilege role subject to RLS — used by the running API at runtime.
DATABASE_URL=postgres://floxio:floxio_dev_password@localhost:5434/floxio
DATABASE_URL_APP=postgres://floxio_app:floxio_app_dev_password@localhost:5434/floxio

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Secrets
ENCRYPTION_KEY=change-me-32-byte-hex-string-change-me
SESSION_SECRET=change-me-to-a-long-random-string

# API
API_PORT=3001
API_BASE_URL=http://localhost:3001

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Telegram (Д7)
# TELEGRAM_BOT_TOKEN=

# IMAP (per-tenant config stored in DB, not here)
